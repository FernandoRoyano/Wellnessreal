# ============================================
# CONFIGURACIÓN DE EMAIL - WellnessReal
# ============================================
# Copia este archivo a .env.local y configura tus credenciales

# --------------------------------------------
# OPCIÓN 1: Resend (Recomendado, GRATIS, arregla el spam)
# --------------------------------------------
# 1. Crea cuenta gratis en https://resend.com
# 2. Domains > Add domain: wellnessreal.es → añade en tu DNS los registros
#    SPF/DKIM/DMARC que te da (gratis). Espera a que salga "Verified".
# 3. API Keys > crea una y ponla aquí.
# 4. Pon MAIL_FROM=info@wellnessreal.es (ya con el dominio verificado).
# Si RESEND_API_KEY está definida, el envío usa Resend automáticamente.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# --------------------------------------------
# OPCIÓN 2: Nodemailer con SMTP
# --------------------------------------------
# Para Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tu@gmail.com
#   SMTP_PASS=tu-app-password (no tu contraseña normal)
#
# Para tu hosting:
#   Consulta los datos SMTP de tu proveedor
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# --------------------------------------------
# EN USO ACTUALMENTE: Gmail / Google Workspace (src/lib/email.ts)
# --------------------------------------------
# Cuenta que autentica el envío (con contraseña de aplicación, requiere 2FA).
# Para que NO caiga en spam, usa un buzón de tu dominio en Google Workspace
# (ej. info@wellnessreal.es) con DKIM activado en el admin de Workspace.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Remitente visible (opcional). Por defecto = GMAIL_USER. Solo cámbialo si ese
# buzón está autenticado/verificado para el dominio; si no, irá a spam.
# MAIL_FROM=info@wellnessreal.es

# --------------------------------------------
# OPCIÓN 3: SendGrid
# --------------------------------------------
# 1. Crea cuenta en https://sendgrid.com
# 2. Ve a Settings > API Keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# --------------------------------------------
# MAILERLITE (Newsletter)
# --------------------------------------------
# 1. Ve a mailerlite.com > Settings > API
# 2. Copia tu API key
# 3. (Opcional) Crea un grupo y copia su ID
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# ============================================
# SANITY CMS (Blog)
# ============================================
# 1. Crea proyecto en https://sanity.io/manage
# 2. Copia el Project ID
# 3. El dataset por defecto es "production"
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ============================================
# SISTEMA DE CLIENTES (Propuestas + Pagos)
# ============================================

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/wellnessreal

# Admin Panel
ADMIN_PASSWORD=

# Stripe (Pagos con tarjeta)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Datos bancarios (se muestran al cliente para transferencia)
BANK_IBAN=
BANK_BENEFICIARY=
BANK_ENTITY=

# URL base
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# SUPABASE (DB, Storage, Auth de la comunidad)
# ============================================
# Panel de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# anon key (pública, segura para el navegador): habilita el login magic link
# de la comunidad de tiroides.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# service_role key (SECRETA, solo servidor): salta RLS, usada por el backend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# En Supabase > Authentication > URL Configuration añade a "Redirect URLs":
#   http://localhost:3000/auth/callback  y  https://wellnessreal.es/auth/callback

# ============================================
# IA — Generador de programas (Método BASE)
# ============================================
# Clave de Anthropic (Claude). SOLO servidor, nunca en el cliente.
ANTHROPIC_API_KEY=sk-ant-...
# Modelo a usar. Por defecto claude-opus-4-8 (máxima calidad).
# Cambia a claude-sonnet-4-6 para reducir coste cuando lo necesites.
WELLNESS_AI_MODEL=claude-opus-4-8
